#!/usr/bin/env bash
#
# Pre-commit guardrail: run PHP_CodeSniffer + PHPStan on custom code before a
# commit is allowed. Both run through DDEV (see CLAUDE.md), against the
# committed phpcs.xml.dist / phpstan.neon.dist configs.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Bypass for a single commit (use sparingly):
#   git commit --no-verify
set -euo pipefail

# Only run when the staged change actually touches code our analyzers cover.
# (Pure config/content/docs commits skip straight through.)
staged=$(git diff --cached --name-only --diff-filter=ACMR \
  -- web/modules/custom web/themes/custom)
if [ -z "$staged" ]; then
  exit 0
fi

if ! command -v ddev >/dev/null 2>&1; then
  echo "pre-commit: ddev not found — skipping phpcs/phpstan." >&2
  echo "           Run the checks manually before pushing." >&2
  exit 0
fi

# If the project isn't up, the checks can't run — warn loudly, don't block work.
if ! ddev exec true >/dev/null 2>&1; then
  echo "pre-commit: DDEV project not running — skipping checks (run 'ddev start')." >&2
  exit 0
fi

echo "pre-commit: running phpcs + phpstan on custom code…"

fail=0
ddev exec composer phpcs   || fail=1
ddev exec composer phpstan || fail=1

if [ "$fail" -ne 0 ]; then
  echo >&2
  echo "pre-commit: checks failed — fix the issues above." >&2
  echo "           Style: 'ddev exec composer phpcbf' auto-fixes most of it." >&2
  echo "           Bypass (sparingly): 'git commit --no-verify'." >&2
  exit 1
fi

echo "pre-commit: ✓ phpcs + phpstan clean"
